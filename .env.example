APP_ENV=local

# Optional MySQL connection. Without these values, Wedora runs from PHP seed data
# and stores visitor state in the PHP session.
DB_HOST=127.0.0.1
DB_NAME=wedora
DB_USER=root
DB_PASS=
# DB_DSN=mysql:host=127.0.0.1;dbname=wedora;charset=utf8mb4

# Optional server-side AI concierge key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
